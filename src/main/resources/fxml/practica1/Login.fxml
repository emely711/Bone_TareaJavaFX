<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="380" prefWidth="350" spacing="15" style="-fx-padding: 40; -fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tarea.javafx.practica1.LoginController">

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="SISTEMA DE ACCESO" />

    <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;" text="Ingrese sus credenciales" />

    <VBox maxWidth="280" spacing="5">
        <Label style="-fx-font-weight: bold;" text="Usuario" />
        <TextField fx:id="txtUsuario" prefWidth="280" promptText="Ingrese usuario" />
    </VBox>

    <VBox maxWidth="280" spacing="5">
        <Label style="-fx-font-weight: bold;" text="Contraseña" />
        <PasswordField fx:id="txtContrasena" prefWidth="280" promptText="Ingrese contraseña" />
    </VBox>

    <VBox maxWidth="280" spacing="5">
        <Label style="-fx-font-weight: bold;" text="Rol" />
        <ComboBox fx:id="cmbRol" prefWidth="280" />
    </VBox>

    <Label fx:id="lblMensaje" maxWidth="280" style="-fx-text-fill: red; -fx-font-size: 12px;" text="" wrapText="true" />

    <HBox alignment="CENTER" spacing="15">
        <Button onAction="#handleIngresar" prefWidth="120" style="-fx-background-color: #2980b9; -fx-text-fill: white;                        -fx-font-weight: bold; -fx-padding: 8 25;" text="Ingresar" />
        <Button onAction="#handleSalir" prefWidth="120" style="-fx-background-color: #e74c3c; -fx-text-fill: white;                        -fx-font-weight: bold; -fx-padding: 8 25;" text="Salir" />
    </HBox>
</VBox>
